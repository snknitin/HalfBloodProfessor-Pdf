{
  "name": "promo-video",
  "version": "1.0.0",
  "description": "Silent looping hb-pdf landing-page promo",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.495",
    "@remotion/fonts": "4.0.495",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.495"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.495",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "render:wide": "remotion render HbPdfPromo ../outputs/hb-pdf-promo-16x9.mp4 --codec=h264 --crf=16 --muted",
    "render:portrait": "remotion render HbPdfPromoPortrait ../outputs/hb-pdf-promo-4x5.mp4 --codec=h264 --crf=16 --muted"
  },
  "sideEffects": [
    "*.css"
  ]
}
